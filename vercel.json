{
  "functions": {
    "api/lead.js": {
      "runtime": "@vercel/node@3.2.24"
    }
  },
  "cleanUrls": false,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
